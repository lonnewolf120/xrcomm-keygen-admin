<%- include("partials/header") %>

<!-- Breadcrumb -->
<nav id="breadcrumbs" class="flex items-center gap-2 text-sm mb-8">
    <a href="/">Dashboard</a>
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4 text-slate-600">
        <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" />
    </svg>
    <a href="/product/<%= product.id %>" class="hover:text-slate-200"><%= product.attributes.name %></a>
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4 text-slate-600">
        <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" />
    </svg>
    <span class="text-slate-100 font-semibold">Create Policy</span>
</nav>

<!-- Header -->
<div class="header-card">
    <h1>Create License Policy</h1>
    <p class="subtitle">Define terms and conditions for <%= product.attributes.name %></p>
</div>

<!-- Form -->
<div class="content-card max-w-3xl">
    <% if (typeof error !== "undefined") { %>
        <div class="alert-error mb-6">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5 inline mr-2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4m0 4v.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <%= error %>
        </div>
    <% } %>

    <form method="POST" action="/product/<%= product.id %>/policies/create" class="flex flex-col gap-6">
        <div>
            <p class="text-sm font-semibold text-slate-300 mb-4">Product: <span class="text-blue-400"><%= product.attributes.name %></span></p>
        </div>

        <label>
            <div>Policy Configuration (JSON)</div>
            <textarea name="data" required class="w-full h-80"><%= typeof data !== "undefined" ? data : `{
  "name": "Professional Edition",
  "duration": 365,
  "maxMachines": 3,
  "floating": false,
  "strict": true,
  "machineUniquenessStrategy": "UNIQUE_PER_POLICY",
  "machineMatchingStrategy": "MATCH_ANY"
}` %></textarea>
            <p class="text-xs text-slate-500 mt-2">Define license duration, machine limits, and validation strategy. See <a href="https://keygen.sh/docs/api/policies/#policies-create-attrs" target="_blank" class="text-blue-400 hover:text-blue-300">Keygen API docs</a> for all options.</p>
        </label>

        <div class="flex gap-3">
            <button type="submit" class="btn btn-primary flex-1">Create Policy</button>
            <a href="/product/<%= product.id %>" class="btn btn-secondary flex-1 text-center">Cancel</a>
        </div>
    </form>
</div>

<%- include("partials/footer") %>