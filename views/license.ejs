<%- include("partials/header") %>

<!-- Breadcrumb -->
<nav id="breadcrumbs" class="flex items-center gap-2 text-sm mb-8">
    <a href="/">Dashboard</a>
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4 text-slate-600">
        <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" />
    </svg>
    <a href="/product/<%= license.relationships.product.data.id %>" class="hover:text-slate-200">Product</a>
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4 text-slate-600">
        <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" />
    </svg>
    <span class="text-slate-100 font-semibold">License Details</span>
</nav>

<!-- Header -->
<div class="header-card">
    <h1>License Details</h1>
    <p class="subtitle">License key and customer activation information</p>
</div>

<!-- License Information -->
<div class="content-card mb-8">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <!-- Left Column -->
        <div>
            <div class="mb-6">
                <p class="text-xs text-slate-400 uppercase font-semibold">License ID</p>
                <p class="font-mono text-sm text-slate-200 mt-2 break-all"><%= license.id %></p>
            </div>
            <div class="mb-6">
                <p class="text-xs text-slate-400 uppercase font-semibold">License Key</p>
                <div class="mt-2 bg-slate-900/50 rounded-lg p-3 font-mono text-sm text-slate-200 break-all border border-slate-600/50">
                    <%= license.attributes.key %>
                </div>
            </div>
            <div class="mb-6">
                <p class="text-xs text-slate-400 uppercase font-semibold">Customer Email</p>
                <p class="text-slate-200 mt-2"><%= license.attributes.metadata.email %></p>
            </div>
            <div>
                <p class="text-xs text-slate-400 uppercase font-semibold">Edition</p>
                <p class="text-slate-200 mt-2"><%= license.attributes.metadata.edition || 'Standard' %></p>
            </div>
        </div>

        <!-- Right Column -->
        <div>
            <div class="mb-6">
                <p class="text-xs text-slate-400 uppercase font-semibold">Status</p>
                <p class="mt-2">
                    <span class="badge" style="<%= license.attributes.status === 'active' ? 'background-color: rgba(16, 185, 129, 0.1); color: #a7f3d0; border-color: rgba(16, 185, 129, 0.3);' : 'background-color: rgba(100, 116, 139, 0.2); color: #cbd5e1;' %>">
                        <%= license.attributes.status %>
                    </span>
                </p>
            </div>
            <div class="mb-6">
                <p class="text-xs text-slate-400 uppercase font-semibold">Last Validated</p>
                <p class="text-slate-200 mt-2"><%= license.attributes.lastValidated ? new Date(license.attributes.lastValidated).toLocaleString() : 'Never' %></p>
            </div>
            <div class="mb-6">
                <p class="text-xs text-slate-400 uppercase font-semibold">Created</p>
                <p class="text-slate-200 mt-2"><%= new Date(license.attributes.created).toLocaleString() %></p>
            </div>
            <div>
                <p class="text-xs text-slate-400 uppercase font-semibold">Product</p>
                <p class="mt-2">
                    <a href="/product/<%= license.relationships.product.data.id %>" class="text-blue-400 hover:text-blue-300">
                        <%= license.relationships.product.data.id %>
                    </a>
                </p>
            </div>
        </div>
    </div>
</div>

<!-- Actions -->
<div class="flex justify-end gap-3 mb-8">
    <a href="/license/<%= license.id %>/delete" class="btn btn-danger" onclick="return confirm('Are you sure you want to delete this license? This action cannot be undone.')">
        Delete License
    </a>
</div>

<!-- License Metadata JSON (Advanced) -->
<div class="content-card opacity-75">
    <h3 class="text-sm font-bold text-slate-300 mb-3">Raw Metadata</h3>
    <pre class="font-mono text-xs text-slate-400 bg-slate-900/50 p-4 rounded-lg overflow-x-auto"><%= JSON.stringify(license.attributes.metadata, null, 2) %></pre>
</div>

<%- include("partials/footer") %>