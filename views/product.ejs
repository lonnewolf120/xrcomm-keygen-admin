<%- include("partials/header") %>

<!-- Breadcrumb -->
<nav id="breadcrumbs" class="flex items-center gap-2 text-sm mb-8">
    <a href="/">Dashboard</a>
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4 text-slate-600">
        <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" />
    </svg>
    <a href="/products" class="hover:text-slate-200">Products</a>
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4 text-slate-600">
        <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" />
    </svg>
    <span class="text-slate-100 font-semibold"><%= product.attributes.name %></span>
</nav>

<!-- Header -->
<div class="header-card">
    <h1><%= product.attributes.name %></h1>
    <p class="subtitle">View policies, licenses, and customer access</p>
</div>

<!-- Product Details Card -->
<div class="content-card mb-8">
    <h2 class="text-xl font-bold mb-4">Product Details</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="bg-slate-900/50 rounded-lg p-4">
            <p class="text-xs text-slate-400 uppercase font-semibold">Product ID</p>
            <p class="font-mono text-sm text-slate-200 mt-2 break-all"><%= product.id %></p>
        </div>
        <div class="bg-slate-900/50 rounded-lg p-4">
            <p class="text-xs text-slate-400 uppercase font-semibold">Account ID</p>
            <p class="font-mono text-sm text-slate-200 mt-2 break-all"><%= process.env.KEYGEN_ACCOUNT_ID %></p>
        </div>
        <div class="bg-slate-900/50 rounded-lg p-4">
            <p class="text-xs text-slate-400 uppercase font-semibold">Created</p>
            <p class="text-sm text-slate-200 mt-2"><%= new Date(product.attributes.created).toLocaleDateString() %></p>
        </div>
    </div>
</div>

<!-- Policies Section -->
<div class="mb-8">
    <div class="section-header">
        <h2 class="title">Policies</h2>
        <a href="/product/<%= product.id %>/policies/create" class="btn btn-primary btn-small inline-flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
            </svg>
            Add Policy
        </a>
    </div>

    <div class="content-card">
        <% if (policies.length === 0) { %>
            <p class="text-slate-400 text-center py-8">No policies defined. Create one to issue licenses.</p>
        <% } else { %>
            <div class="overflow-x-auto">
                <table>
                    <thead>
                        <tr>
                            <th>Policy Name</th>
                            <th>Configuration</th>
                            <th>Created</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% for (const policy of policies) { %>
                        <tr>
                            <td class="font-semibold"><%= policy.attributes.name %></td>
                            <td>
                                <div class="text-xs space-y-1">
                                    <div class="text-slate-300">Duration: <span class="text-blue-400"><%= policy.attributes.duration === -1 ? '∞' : policy.attributes.duration + 'd' %></span></div>
                                    <div class="text-slate-300">Max Machines: <span class="text-blue-400"><%= policy.attributes.maxMachines === -1 ? '∞' : policy.attributes.maxMachines %></span></div>
                                    <div class="text-slate-300">Floating: <span class="text-blue-400"><%= policy.attributes.floating ? 'Yes' : 'No' %></span></div>
                                </div>
                            </td>
                            <td><%= new Date(policy.attributes.created).toLocaleDateString() %></td>
                        </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        <% } %>
    </div>
</div>

<!-- Licenses Section -->
<div>
    <div class="section-header">
        <h2 class="title">Licenses</h2>
        <a href="/product/<%= product.id %>/licenses/create" class="btn btn-primary btn-small inline-flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
            </svg>
            Issue License
        </a>
    </div>

    <div class="content-card">
        <% if (licenses.length === 0) { %>
            <p class="text-slate-400 text-center py-8">No licenses issued yet.</p>
        <% } else { %>
            <div class="overflow-x-auto">
                <table>
                    <thead>
                        <tr>
                            <th>Customer Email</th>
                            <th>License Key</th>
                            <th>Status</th>
                            <th>Last Validated</th>
                            <th class="action">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% for (const license of licenses) { %>
                        <tr>
                            <td><%= license.attributes.metadata.email %></td>
                            <td class="mono"><%= license.attributes.key.substring(0, 12) %>...</td>
                            <td>
                                <span class="badge" style="<%= license.attributes.status === 'active' ? 'background-color: rgba(16, 185, 129, 0.1); color: #a7f3d0; border-color: rgba(16, 185, 129, 0.3);' : 'background-color: rgba(100, 116, 139, 0.2); color: #cbd5e1;' %>">
                                    <%= license.attributes.status %>
                                </span>
                            </td>
                            <td><%= license.attributes.lastValidated ? new Date(license.attributes.lastValidated).toLocaleDateString() : 'Never' %></td>
                            <td class="action">
                                <a href="/license/<%= license.id %>" class="text-blue-400 hover:text-blue-300 text-sm font-semibold">
                                    View →
                                </a>
                            </td>
                        </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        <% } %>
    </div>
</div>

<%- include("partials/footer") %>