<%- include("partials/header") %>

<!-- Breadcrumb -->
<nav id="breadcrumbs" class="flex items-center gap-2 text-sm mb-8">
    <a href="/">Dashboard</a>
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4 text-slate-600">
        <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" />
    </svg>
    <a href="/products" class="hover:text-slate-200">Products</a>
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4 text-slate-600">
        <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" />
    </svg>
    <span class="text-slate-100 font-semibold">Create Product</span>
</nav>

<!-- Header -->
<div class="header-card">
    <h1>Create New Product</h1>
    <p class="subtitle">Add a new XRComm GRPC product to your license management system</p>
</div>

<!-- Form -->
<div class="content-card max-w-2xl">
    <% if (typeof error !== "undefined") { %>
        <div class="alert-error mb-6">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5 inline mr-2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4m0 4v.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <%= error %>
        </div>
    <% } %>

    <form method="POST" action="/products/create" class="flex flex-col gap-6">
        <label>
            <div>Product Name</div>
            <input type="text" name="name" placeholder="e.g., XRComm Enterprise, XRComm Studio" required class="w-full" />
            <p class="text-xs text-slate-500 mt-2">The name of your product offering</p>
        </label>

        <div class="flex gap-3">
            <button type="submit" class="btn btn-primary flex-1">Create Product</button>
            <a href="/products" class="btn btn-secondary flex-1 text-center">Cancel</a>
        </div>
    </form>
</div>

<%- include("partials/footer") %>