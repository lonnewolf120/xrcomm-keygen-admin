<%- include("partials/header") %>

<!-- Breadcrumb -->
<nav id="breadcrumbs" class="flex items-center gap-2 text-sm mb-8">
    <a href="/">Dashboard</a>
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4 text-slate-600">
        <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" />
    </svg>
    <span class="text-slate-100 font-semibold">Products</span>
</nav>

<!-- Header -->
<div class="header-card">
    <div class="flex items-center justify-between">
        <div>
            <h1>Products</h1>
            <p class="subtitle">XRComm GRPC product offerings and licensing tiers</p>
        </div>
        <a href="/products/create" class="btn btn-primary btn-small inline-flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
            </svg>
            Add Product
        </a>
    </div>
</div>

<!-- Products Table -->
<div class="content-card">
    <% if (products.length === 0) { %>
        <div class="text-center py-12">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-12 h-12 text-slate-600 mx-auto mb-4">
                <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 6.375c0 2.278-3.694 4.125-8.25 4.125S3.75 8.653 3.75 6.375m16.5 0c0-2.278-3.694-4.125-8.25-4.125S3.75 4.097 3.75 6.375m16.5 0v11.25c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125V6.375" />
            </svg>
            <p class="text-slate-400">No products created yet</p>
            <a href="/products/create" class="btn btn-primary btn-small mt-4">Create First Product</a>
        </div>
    <% } else { %>
        <div class="overflow-x-auto">
            <table>
                <thead>
                    <tr>
                        <th>Product Name</th>
                        <th>ID</th>
                        <th>Created</th>
                        <th class="action">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% for (const product of products) { %>
                    <tr>
                        <td>
                            <a href="/product/<%= product.id %>" class="font-semibold hover:text-blue-300">
                                <%= product.attributes.name %>
                            </a>
                        </td>
                        <td class="mono"><%= product.id.substring(0, 8) %>...</td>
                        <td><%= new Date(product.attributes.created).toLocaleDateString() %></td>
                        <td class="action">
                            <a href="/product/<%= product.id %>" class="text-blue-400 hover:text-blue-300 text-sm font-semibold">
                                Manage →
                            </a>
                        </td>
                    </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    <% } %>
</div>

<%- include("partials/footer") %>