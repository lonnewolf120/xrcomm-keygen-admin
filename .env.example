# XRComm GRPC License Admin - Environment Configuration
# Copy this to .env and fill in your values

# Server Configuration
PORT=3000
NODE_ENV=development

# Keygen Self-Hosted Instance (Community Edition)
# Point to your self-hosted Keygen CE instance
KEYGEN_BASE_URL=http://localhost:8000
KEYGEN_ACCOUNT_ID=your-account-id
KEYGEN_ACCOUNT_EMAIL=admin@example.com
KEYGEN_ACCOUNT_PASSWORD=your-keygen-password

# Admin Dashboard Authentication
# Basic HTTP Auth credentials
SITE_USER=admin
SITE_PASSWORD=your-secure-password

# Session signing secret used by express-session
# If omitted, the app falls back to SITE_PASSWORD
SECRET=replace-with-a-long-random-string

# Email Configuration (Optional - Postmark)
# Used for sending license keys to customers
POSTMARK_API_KEY=
POSTMARK_FROM_EMAIL=licenses@example.com

# Paddle Integration (Optional)
# For automated license generation on purchase
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=
PRODUCT_POLICY_MAPPING={"paddle_product_id":"keygen_policy_id"}
